{
  "name": "auris-mcp",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Auris MCP server — a thin stdio MCP client that exposes the engine's generate/settings to AI tools. Holds zero generation logic; talks to the engine over HTTP only.",
  "scripts": {
    "dev": "tsx src/index.ts",
    "start": "tsx src/index.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "dotenv": "^17.4.2",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsx": "^4.20.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.7"
  }
}
