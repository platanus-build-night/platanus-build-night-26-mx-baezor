# ─── Engine ────────────────────────────────────────────────
ENGINE_PORT=3000
ADMIN_ORIGIN=http://localhost:5173

# ─── Provider selection (factory reads these) ──────────────
LLM_PROVIDER=claude
TTS_PROVIDER=elevenlabs
STORAGE_PROVIDER=local

# ─── Anthropic (LLM) ───────────────────────────────────────
# Required only for the live demo (mock providers need no keys).
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# ─── ElevenLabs (TTS) ──────────────────────────────────────
# Required only for the live demo (mock providers need no keys).
ELEVENLABS_API_KEY=
# Required only for the live demo (mock providers need no keys).
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL=eleven_multilingual_v2

# ─── Storage ───────────────────────────────────────────────
AUDIO_DIR=./audio

# ─── Demo cache (empty = disabled) ─────────────────────────
DEMO_CACHE_DIR=

# ─── Caps ──────────────────────────────────────────────────
MAX_UPLOAD_MB=10
INPUT_CHAR_CAP=6000

# ─── Other modules (optional — defaults to http://localhost:3000) ─
# whatsapp/ and admin/ run on built-in defaults and only need these if the
# engine is NOT at http://localhost:3000. Each reads its OWN module .env (not
# this root file) — set them in whatsapp/.env and admin/.env respectively.
#
# whatsapp/.env → engine base URL (else built from ENGINE_PORT, default :3000)
# ENGINE_URL=http://localhost:3000
#
# admin/.env → engine base URL (Vite)
# VITE_ENGINE_URL=http://localhost:3000
